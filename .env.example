# Consilience — environment variables
# Copy to the appropriate location per service; never commit real values.

# ── Database (Neon Postgres) ─────────────────────────────────────────
# Used by: gateway, mesh, engine
# Get from: Neon console → project "consilience" → connection string
DATABASE_URL=

# ── Auth (Clerk) ─────────────────────────────────────────────────────
# Used by: apps/web (publishable), gateway (secret, for JWT verification)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Message broker (RabbitMQ) ────────────────────────────────────────
# Used by: gateway, mesh, engine — local default shown, hosted value in prod
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── LLM providers ────────────────────────────────────────────────────
# Used by: mesh (from Milestone 2)
GEMINI_API_KEY=
